{
	"name": "@gramio/format",
	"version": "0.4.0",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gramiojs/format.git"
	},
	"main": "./dist/index.js",
	"dependencies": {
		"@gramio/types": "^9.1.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.1.1",
		"@types/bun": "^1.2.18",
		"expect-type": "^1.2.2",
		"marked": "^16.0.0",
		"node-html-parser": "^7.0.2",
		"pkgroll": "^2.14.1",
		"prettier": "^3.6.2",
		"typescript": "^5.8.3"
	},
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.ts",
				"default": "./dist/index.js"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		},
		"./markdown": {
			"import": {
				"types": "./dist/markdown/index.d.ts",
				"default": "./dist/markdown/index.js"
			},
			"require": {
				"types": "./dist/markdown/index.d.cts",
				"default": "./dist/markdown/index.cjs"
			}
		},
		"./html": {
			"import": {
				"types": "./dist/html/index.d.ts",
				"default": "./dist/html/index.js"
			},
			"require": {
				"types": "./dist/html/index.d.cts",
				"default": "./dist/html/index.cjs"
			}
		},
		"./dist/*": {
			"import": {
				"types": "./dist/*/index.d.ts",
				"default": "./dist/*/index.js"
			}
		}
	},
	"description": "Library for formatting text for Telegram Bot API",
	"files": [
		"dist"
	],
	"homepage": "https://gramio.dev/formatting.html",
	"keywords": [
		"gramio",
		"telegram",
		"bot",
		"formatting",
		"markdown",
		"html",
		"markdownV2"
	],
	"license": "MIT",
	"peerDependenciesMeta": {
		"marked": {
			"optional": true
		},
		"node-html-parser": {
			"optional": true
		}
	},
	"peerDependencies": {
		"marked": "^15.0.11",
		"node-html-parser": ">=6.0.0"
	},
	"scripts": {
		"prepublishOnly": "bunx pkgroll",
		"generate": "bun scripts/generate.ts",
		"lint": "bunx @biomejs/biome check ./src",
		"lint:fix": "bun lint --apply"
	},
	"type": "module"
}
